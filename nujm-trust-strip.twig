{#
| Variable | Type  | Description       |
|----------|-------|-------------------|
| component.items | array | Trust benefits |
#}

{% set items = component.items|default([]) %}

{% if items|length %}
  <section class="nujm-section nujm-trust" data-nujm-reveal>
    <div class="container">
      <div class="nujm-trust__grid">
        {% for item in items %}
          <div class="nujm-trust__item">
            {% if item.icon %}
              <i class="{{ item.icon }}"></i>
            {% endif %}
            <div>
              {% if item.title %}
                <h3>{{ item.title }}</h3>
              {% endif %}
              {% if item.description %}
                <p>{{ item.description }}</p>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </section>
{% endif %}
